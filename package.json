{
  "name": "deal-analyzer-mcp",
  "version": "1.7.0",
  "main": "dist/server.js",
  "scripts": {
    "build": "npm run build:client && tsc",
    "build:client": "npm --prefix client run build",
    "check": "tsc --noEmit",
    "check:client": "npm --prefix client run check",
    "dev": "tsx watch src/server.ts",
    "dev:all": "concurrently -k -n server,client -c blue,green \"npm run dev\" \"npm run dev:client\"",
    "dev:client": "npm --prefix client run dev",
    "eval": "tsx src/eval.ts",
    "eval:prod": "tsx src/eval.ts https://deal-analyzer-mcp-production.up.railway.app",
    "start": "node dist/server.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "better-sqlite3": "^12.9.0",
    "cheerio": "^1.0.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "stripe": "^22.0.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.1",
    "@types/node": "^22.13.10",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
