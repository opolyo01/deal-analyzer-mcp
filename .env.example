PORT=3000
SESSION_SECRET=replace-with-a-long-random-string
PUBLIC_BASE_URL=http://localhost:3000

# Google OAuth login. Create these in Google Cloud Console.
# Authorized JavaScript origin: http://localhost:3000
# Authorized redirect URI: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Built-in OAuth client for local /authorize + /token testing.
DEFAULT_OAUTH_CLIENT_ID=chatgpt-dev-client
DEFAULT_OAUTH_REDIRECT_URIS=http://localhost:3000/dashboard

# Deal assumptions.
DEFAULT_RATE=0.065
DEFAULT_TERM_YEARS=30
DEFAULT_VACANCY_RATE=0.05
DEFAULT_REPAIRS_RATE=0.05
DEFAULT_CAPEX_RATE=0.05
DEFAULT_MANAGEMENT_RATE=0.08

# Railway deployment values should use your public app URL instead:
# PUBLIC_BASE_URL=https://deal-analyzer-mcp-production.up.railway.app
# GOOGLE_CALLBACK_URL=https://deal-analyzer-mcp-production.up.railway.app/auth/google/callback
# DEFAULT_OAUTH_REDIRECT_URIS=https://deal-analyzer-mcp-production.up.railway.app/dashboard
